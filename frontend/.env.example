# =============================================================================
# Electricity Optimizer Frontend - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values

# Backend API URL (relative path uses Next.js rewrite proxy for same-origin requests)
NEXT_PUBLIC_API_URL=/api/v1

# Backend server URL (server-side only — used by Next.js rewrites and API routes)
BACKEND_URL=http://localhost:8000

# Public app URL (used by Better Auth for trusted origins and OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon PostgreSQL (used by Better Auth server for session management)
# Project: cold-rice-23455092 ("energyoptimize"), pooled endpoint: ep-withered-morning
# Better Auth appends ?options=-csearch_path=neon_auth,public automatically
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-withered-morning-aix83cfw-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# Better Auth — session signing and base URL
# BETTER_AUTH_SECRET: Generate with: openssl rand -hex 32
# BETTER_AUTH_URL: Must match the public URL of this frontend
# BETTER_AUTH_SECRET=your-better-auth-secret-here
# BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers (optional — social login buttons are hidden when these are absent)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth button visibility (set to "true" to show OAuth buttons in UI)
# NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=true
# NEXT_PUBLIC_OAUTH_GITHUB_ENABLED=true

# Email sending via Resend (required for email verification and magic links)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM_ADDRESS=Electricity Optimizer <onboarding@resend.dev>

# Analytics (Microsoft Clarity — free, unlimited, no card)
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# Push Notifications (OneSignal — free tier, unlimited mobile push, no card)
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
